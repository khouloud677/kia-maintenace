generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BookingChannel {
  GUEST
  MOBILE
}

enum AppointmentStatus {
  PENDING
  IN_PROGRESS
  READY
  CANCELLED
}

enum VerificationChannel {
  SMS
  EMAIL
}

model User {
  id          String        @id @default(cuid())
  keycloakSub String        @unique
  email       String?
  fullName    String?
  phone       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  cars        Car[]
  appointments Appointment[]
}

model Car {
  id             String         @id @default(cuid())
  vin            String         @unique
  matricule      String?
  normalizedPlate String
  isForeign      Boolean        @default(false)
  ownerId        String?
  owner          User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  appointments   Appointment[]

  @@index([normalizedPlate])
}

model GuestSession {
  id                 String               @id @default(cuid())
  token              String               @unique
  contactChannel     VerificationChannel
  contactValue       String
  verificationHash   String
  verifiedAt         DateTime?
  attempts           Int                  @default(0)
  expiresAt          DateTime
  createdAt          DateTime             @default(now())
  appointments       Appointment[]

  @@index([contactValue])
}

model Agency {
  id            String          @id @default(cuid())
  name          String
  city          String
  address       String
  latitude      Float
  longitude     Float
  phone         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  appointments  Appointment[]
  agencyServices AgencyService[]
}

model Service {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  description    String?
  durationMin    Int
  priceEstimate  Decimal?        @db.Decimal(10, 2)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  appointments   Appointment[]
  agencyServices AgencyService[]
}

model AgencyService {
  id        String   @id @default(cuid())
  agencyId  String
  serviceId String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([agencyId, serviceId])
}

model Appointment {
  id             String            @id @default(cuid())
  reference      String            @unique
  channel        BookingChannel
  status         AppointmentStatus @default(PENDING)
  scheduledAt    DateTime
  notes          String?
  contactEmail   String?
  contactPhone   String?
  carId          String
  agencyId       String
  serviceId      String
  userId         String?
  guestSessionId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  car            Car               @relation(fields: [carId], references: [id], onDelete: Restrict)
  agency         Agency            @relation(fields: [agencyId], references: [id], onDelete: Restrict)
  service        Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestSession   GuestSession?     @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)

  @@index([scheduledAt])
  @@index([status])
  @@index([carId, scheduledAt])
}

model Reclamation {
  id          String   @id @default(cuid())
  fullName    String
  email       String?
  phone       String?
  message     String
  appointmentReference String?
  createdAt   DateTime @default(now())
}

model Feedback {
  id          String   @id @default(cuid())
  rating      Int
  comment     String?
  email       String?
  phone       String?
  appointmentReference String?
  createdAt   DateTime @default(now())
}
